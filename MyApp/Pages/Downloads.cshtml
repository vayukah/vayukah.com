@page "/downloads"
@attribute [RenderStatic]
@{
    ViewData["Title"] = "Downloads";

    var latestVersion = new VersionEntry
    {
        Version = "v3.2.1",
        Date = "12 March 2025",
        Notes = "New terrain-follow mode, bug fixes for multi-drone sync, improved UI",
        DownloadUrl = "http://192.168.0.113:9000/dronesharpgcs/latest/DronesharpGCS-installer.exe",
        FileName = "DronesharpGCS-installer.exe",
        PlayStoreUrl = "https://play.google.com/store/apps/details?id=com.aerogcs.aerogcsenterprise.hellodrone&pli=1"
    };

    var previousVersions = new List<VersionEntry>
    {
        new VersionEntry { Version = "v3.1.0", Date = "5 Jan 2025",   Notes = "Added mission presets, multiple map providers",        DownloadUrl = "/files/DroneSharpGCS_v3.1.0_Setup.exe" , FileName = "DronesharpGCS-installer.exe", PlayStoreUrl = "https://play.google.com/store/apps/details?id=com.aerogcs.aerogcsenterprise.hellodrone&pli=1"},
        new VersionEntry { Version = "v3.0.0", Date = "10 Oct 2024",  Notes = "Major release — multi drone support, audible prompts",  DownloadUrl = "/files/DroneSharpGCS_v3.0.0_Setup.exe", FileName = "DronesharpGCS-installer.exe", PlayStoreUrl = "https://play.google.com/store/apps/details?id=com.aerogcs.aerogcsenterprise.hellodrone&pli=1"},
        new VersionEntry { Version = "v2.8.4", Date = "3 Jul 2024",   Notes = "Stability patches, telemetry improvements",            DownloadUrl = "/files/DroneSharpGCS_v2.8.4_Setup.exe", FileName = "DronesharpGCS-installer.exe", PlayStoreUrl = "https://play.google.com/store/apps/details?id=com.aerogcs.aerogcsenterprise.hellodrone&pli=1"},
    };
}

@functions {
    class VersionEntry
    {
        public string Version    { get; set; } = "";
        public string Date       { get; set; } = "";
        public string Notes      { get; set; } = "";
        public string DownloadUrl { get; set; } = "";
        public string FileName { get; set; } = "";
        public string PlayStoreUrl { get; set; } = "";
    }
}

<div class="downloads-page">

    <div class="downloads-header">
        <h1 class="product-title text-slate-900 dark:text-slate-50">Dronesharp GCS</h1>
        <p class="product-subtitle text-slate-800 dark:text-slate-50">Ground Control Software for Vigor UAV — Windows</p>
    </div>

    <section class="section">
        <div class="section-label">
            <span class="badge-latest">Latest release</span>
        </div>

        <div class="card card-latest">
            <div class="card-body">
                <div class="version-info">
                    <span class="version-number">@latestVersion.Version</span>
                    <span class="version-meta">Released @latestVersion.Date &nbsp;·&nbsp; Stable</span>
                    <p class="version-notes">@latestVersion.Notes</p>
                </div>
                <button onclick="triggerDownload('@latestVersion.DownloadUrl', '@latestVersion.FileName', this)" class="btn-download btn-download-primary">
                    <svg class="btn-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8 2v8m0 0L5 7m3 3l3-3M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="btn-label">Download .exe</span>
                </button>
                 <a href="@latestVersion.PlayStoreUrl" target="_blank" class="btn-download btn-playstore">
                    <svg class="btn-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 2.5L13 8 3 13.5V2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                    </svg>
                    Play Store
                 </a>
            </div>
        </div>
    </section>

    <section class="section">
        <p class="prev-label text-slate-700 dark:text-slate-50">Previous versions</p>

        <div class="versions-list">
            @foreach (var v in previousVersions)
            {
                <div class="card card-prev">
                    <div class="card-body">
                        <div class="version-info">
                            <span class="version-number version-number-sm">@v.Version</span>
                            <span class="version-meta">@v.Date</span>
                            <p class="version-notes version-notes-sm">@v.Notes</p>
                        </div>
                        <button onclick="triggerDownload('@v.DownloadUrl', '@v.FileName', this)" class="btn-download btn-download-secondary">
                            <svg class="btn-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M8 2v8m0 0L5 7m3 3l3-3M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <span class="btn-label">Download .exe</span>
                        </button>
                        @if (!string.IsNullOrEmpty(v.PlayStoreUrl))
                        {
                            <a href="@v.PlayStoreUrl" target="_blank" class="btn-download btn-playstore btn-playstore-sm">
                                <svg class="btn-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M3 2.5L13 8 3 13.5V2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                                </svg>
                                Play Store
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

</div>

<script>
    async function triggerDownload(url, fileName, btn) {
        const label = btn.querySelector('.btn-label');
        const originalText = label.innerText;

        btn.disabled = true;
        label.innerText = 'Downloading…';

        try {
            const response = await fetch(url);
            if (!response.ok) throw new Error('Network response was not ok');

            const blob = await response.blob();
            const blobUrl = URL.createObjectURL(blob);

            const a = document.createElement('a');
            a.href = blobUrl;
            a.download = fileName;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(blobUrl);

            label.innerText = 'Done!';
            setTimeout(() => {
                label.innerText = originalText;
                btn.disabled = false;
            }, 2000);
        } catch (err) {
            label.innerText = 'Failed — retry';
            btn.disabled = false;
            console.error('Download error:', err);
        }
    }
</script>

<style>
    .downloads-page {
        max-width: 760px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
        font-family: inherit;
    }

    .downloads-header {
        margin-bottom: 2rem;
    }

    .product-title {
        font-size: 1.75rem;
        font-weight: 600;
        margin: 0 0 0.25rem;
    }

    .product-subtitle {
        font-size: 0.9rem;
        margin: 0;
    }

    .section {
        margin-bottom: 2rem;
    }

    .section-label {
        margin-bottom: 0.75rem;
    }

    .badge-latest {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 500;
        background: #dcfce7;
        color: #166534;
        padding: 3px 10px;
        border-radius: 6px;
    }

    @@media (prefers-color-scheme: dark) {
        .badge-latest { background: #14532d; color: #86efac; }
    }

    .card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
    }

    @@media (prefers-color-scheme: dark) {
        .card { background: #1e293b; border-color: #334155; }
    }

    .card-latest {
        border-left: 3px solid #22c55e;
    }

    .card-body {
        padding: 1.25rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .version-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .version-number {
        font-size: 1rem;
        font-weight: 600;
        color: #0f172a;
    }

    .version-number-sm {
        font-size: 0.9rem;
    }

    .version-meta {
        font-size: 0.8rem;
        color: #64748b;
    }

    .version-notes {
        font-size: 0.82rem;
        color: #64748b;
        margin: 2px 0 0;
    }

    .version-notes-sm {
        font-size: 0.78rem;
    }

    @@media (prefers-color-scheme: dark) {
        .version-number { color: #f1f5f9; }
        .version-meta   { color: #94a3b8; }
        .version-notes  { color: #94a3b8; }
    }

    .prev-label {
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin: 0 0 0.75rem;
    }

    .versions-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .btn-download {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
        border-radius: 8px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s;
        cursor: pointer;
        border: 1px solid transparent;
    }

    .btn-icon {
        width: 15px;
        height: 15px;
        flex-shrink: 0;
    }

    .btn-download-primary {
        font-size: 0.85rem;
        padding: 8px 16px;
        background: #0f172a;
        color: #f8fafc;
        border-color: #0f172a;
    }

    .btn-download-primary:hover {
        background: #1e293b;
        border-color: #1e293b;
    }

    .btn-download-secondary {
        font-size: 0.8rem;
        padding: 6px 14px;
        background: transparent;
        color: #0f172a;
        border-color: #cbd5e1;
    }

    .btn-download-secondary:hover {
        background: #f8fafc;
        border-color: #94a3b8;
    }

    .btn-playstore {
        font-size: 0.85rem;
        padding: 8px 16px;
        background: transparent;
        color: #16a34a;
        border-color: #16a34a;
    }

    .btn-playstore:hover {
        background: #f0fdf4;
    }
    
    .btn-playstore-sm {
        font-size: 0.8rem;
        padding: 6px 14px;
    }
    
    @@media (prefers-color-scheme: dark) {
        .btn-playstore { color: #4ade80; border-color: #4ade80; }
        .btn-playstore:hover { background: #052e16; }
    }

    @@media (prefers-color-scheme: dark) {
        .btn-download-primary {
            background: #f1f5f9;
            color: #0f172a;
            border-color: #f1f5f9;
        }
        .btn-download-primary:hover {
            background: #e2e8f0;
            border-color: #e2e8f0;
        }
        .btn-download-secondary {
            color: #f1f5f9;
            border-color: #475569;
        }
        .btn-download-secondary:hover {
            background: #334155;
            border-color: #64748b;
        }
    }

    @@media (max-width: 480px) {
        .card-body {
            flex-direction: column;
            align-items: flex-start;
        }
        .btn-download {
            width: 100%;
            justify-content: center;
        }
    }
</style>