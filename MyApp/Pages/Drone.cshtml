@page "/drone"
@attribute [RenderStatic]
@{
    ViewData["Title"] = "VIGOR";
    const string Web3FormsKey = "ebc811c0-947f-4216-9781-4ffb0db915b2";
    const string ExeUrl       = "https://dronesharpgcs-downloads.s3.ap-south-1.amazonaws.com/releases/VIGOR-S50-Brochure.pdf";
}

<div class="text-center lg:pt-2 sm:pt-2 pt-2 ">
    <section class="text-center mb-4 border-y">
        <div class="grid grid-cols-1 p-4 border-y ">
            <div class="flex items-center justify-center">
                <div class=" flex justify-center">
                    <img class="object-contain " height="auto" width="60%" src="./img/products/Drone/dronelayout.png">
                </div>
            </div>
            <h3 class="mx-auto max-w-4xl lg:my-4 sm:my-2 my-1 font-display text-2xl font-medium tracking-tight text-slate-900 dark:text-slate-50 sm:text-4xl">
                <b>VIGOR S50</b>
            </h3>
        </div>
    </section>
    <div class="mx-auto max-w-4xl lg:my-8 md:my-4 my-2">
        <h1 class=" font-display  font-medium tracking-tight text-slate-900 dark:text-slate-50 lg:text-2xl md:text-lg text-md ">
            A stable platform for Survey, Mapping and Inspection projects with a wide range of lens. Vigor is equipped with RTK module, pivoting camera mount and obstacle detection.
        </h1>
        <div class="flex lg:my-4 my-2 justify-center">
            <button onclick="openBrochureModal()"
                class="group inline-flex items-center justify-center rounded-full py-2 px-4 lg:mx-4 mx-2 text-sm font-semibold focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 text-white hover:opacity-90 active:opacity-75 focus-visible:outline-[#eb8a0c]"
                style="background-color: #eb8a0c;">
                Download Brochure
            </button>
            <a class="group inline-flex items-center justify-center rounded-full py-2 px-4 text-sm font-semibold focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 bg-slate-900 text-white hover:bg-slate-700 hover:text-slate-100 active:bg-slate-800 active:text-slate-300 focus-visible:outline-slate-900" href="/products">
                VIGOR S50 Specs
            </a>
        </div>
    </div>
</div>

<div class="mx-auto max-w-7xl lg:mb-8 md:mb-4 mb-2 grid lg:grid-cols-2 grid-cols-1 gap-y-4 text-center ">
    <div class=" p-4 flex grid grid-cols-1 justify-center border-2 shadow-lg">
        <div class=" flex items-end justify-center">
            <h1 class="text-2xl"><b>Powerhouse of an UAV</b></h1>
        </div>
        <div class="flex items-center justify-center">
            <img class="object-contain " src="./img/products/Drone/dronelayout.png">
        </div>
        <div class="flex items-stretch justify-center">
            <ul class="text-md md:text-lg self-start ">
                <li>Multi-directional range finders</li>
                <li>Obstacle detection and stop</li>
            </ul>    
        </div>
    </div>
    <div class="flex items-center justify-center">
        <div class="  flex grid items-center grid-cols-1 lg:gap-x-3 gap-y-2">
            <div class=" p-4 flex grid grid-cols-1 justify-center border-2 shadow-lg">
                <div class=" flex items-end justify-center">
                    <h1 class="text-2xl"><b>Compact to transport</b></h1>
                </div>
                <img class="object-contain " src="./img/products/Drone/Drone_compact.png">
                <div class="flex items-stretch justify-center">
                    <ul class="text-md md:text-lg self-start ">
                        <li>Fits into a backpack</li>
                        <li>Quick and easy deployment</li>
                    </ul>
                </div>
            </div>
            <div class=" p-4 flex grid grid-cols-1 justify-center border-2 shadow-lg">
                <div class=" flex items-end justify-center">
                    <h1 class="text-2xl"><b>Payload Quick Release</b></h1>
                </div>
                <img class="object-contain " src="./img/products/Drone/Quick_release.png">
                <div class="flex items-stretch justify-center">
                    <ul class="text-md md:text-lg self-start ">
                        <li>Instant payload swap</li>
                        <li>Upto 15 lens combinations</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="brochure-modal" class="modal-overlay" onclick="handleOverlayClick(event)">
    <div class="modal-box">
    
        <div class="modal-header">
            <div>
                <p class="modal-title">Download VIGOR S50 Brochure</p>
                <p class="modal-subtitle">Fill in your details to get the brochure.</p>
            </div>
            <button class="modal-close" onclick="closeBrochureModal()" aria-label="Close">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            </button>
        </div>
    
        <div id="brochure-form-area">
            <div class="form-fields">
    
                <div class="field-group">
                    <label class="field-label">Name <span class="required">*</span></label>
                    <input type="text" id="b-name" placeholder="John Smith" class="field-input" />
                    <span class="field-error" id="b-err-name"></span>
                </div>
    
                <div class="field-group">
                    <label class="field-label">Phone number <span class="required">*</span></label>
                    <input type="tel" id="b-phone" placeholder="+91 98765 43210" class="field-input" />
                    <span class="field-error" id="b-err-phone"></span>
                </div>
    
                <div class="field-group">
                    <label class="field-label">Email <span class="required">*</span></label>
                    <input type="email" id="b-email" placeholder="john@example.com" class="field-input" />
                    <span class="field-error" id="b-err-email"></span>
                </div>
    
                <div class="field-group">
                    <label class="field-label">Organisation <span class="optional">(optional)</span></label>
                    <input type="text" id="b-org" placeholder="Acme Corp" class="field-input" />
                </div>
    
                <div class="field-group">
                    <label class="field-label">Comment <span class="optional">(optional)</span></label>
                    <textarea id="b-comment" placeholder="Anything you'd like to tell us" rows="3" class="field-input field-textarea"></textarea>
                </div>
    
                <div id="b-submit-error" class="submit-error" style="display:none;">
                    Something went wrong. Please try again.
                </div>
    
                <button id="b-submit-btn" onclick="handleBrochureSubmit()" class="submit-btn" style="background-color: #eb8a0c;">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;">
                        <path d="M8 2v8m0 0L5 7m3 3l3-3M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span id="b-submit-label">Submit &amp; Download Brochure</span>
                </button>
    
                <p class="form-hint">Your download will start automatically after submission.</p>
    
            </div>
        </div>
    
        <div id="brochure-success-area" style="display:none;" class="success-area">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="19" stroke="#22c55e" stroke-width="1.5"/>
                <path d="M12 20l6 6 10-12" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <p class="success-title">Thank you!</p>
            <p class="success-msg">Your brochure download has started. Check your downloads folder.</p>
            <button onclick="closeBrochureModal()" class="success-close-btn">Close</button>
        </div>
    
    </div>
</div>

<script>
    const BROCHURE_WEB3KEY = '@Web3FormsKey';
    const BROCHURE_URL     = '@ExeUrl';

    function openBrochureModal() {
        document.getElementById('brochure-modal').classList.add('modal-visible');
        document.body.style.overflow = 'hidden';
    }

    function closeBrochureModal() {
        document.getElementById('brochure-modal').classList.remove('modal-visible');
        document.body.style.overflow = '';
        resetBrochureForm();
    }

    function handleOverlayClick(e) {
        if (e.target === document.getElementById('brochure-modal')) {
            closeBrochureModal();
        }
    }

    function resetBrochureForm() {
        ['b-name','b-phone','b-email','b-org','b-comment'].forEach(id => {
            document.getElementById(id).value = '';
        });
        ['b-err-name','b-err-phone','b-err-email'].forEach(id => {
            document.getElementById(id).innerText = '';
        });
        document.getElementById('b-submit-error').style.display    = 'none';
        document.getElementById('brochure-form-area').style.display = '';
        document.getElementById('brochure-success-area').style.display = 'none';
        document.getElementById('b-submit-label').innerText = 'Submit & Download Brochure';
        document.getElementById('b-submit-btn').disabled   = false;
    }

    function validateBrochureForm() {
        let valid = true;
        const name  = document.getElementById('b-name').value.trim();
        const phone = document.getElementById('b-phone').value.trim();
        const email = document.getElementById('b-email').value.trim();

        document.getElementById('b-err-name').innerText  = '';
        document.getElementById('b-err-phone').innerText = '';
        document.getElementById('b-err-email').innerText = '';

        if (!name)  { document.getElementById('b-err-name').innerText  = 'Name is required.';         valid = false; }
        if (!phone) { document.getElementById('b-err-phone').innerText = 'Phone number is required.'; valid = false; }
        if (!email) {
            document.getElementById('b-err-email').innerText = 'Email is required.';
            valid = false;
        } else if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
            document.getElementById('b-err-email').innerText = 'Enter a valid email address.';
            valid = false;
        }
        return valid;
    }

    async function handleBrochureSubmit() {
        if (!validateBrochureForm()) return;

        const btn   = document.getElementById('b-submit-btn');
        const label = document.getElementById('b-submit-label');

        btn.disabled    = true;
        label.innerText = 'Submitting\u2026';
        document.getElementById('b-submit-error').style.display = 'none';

        const payload = {
            access_key:   BROCHURE_WEB3KEY,
            subject:      'VIGOR S50 Brochure Download Request',
            name:         document.getElementById('b-name').value.trim(),
            phone:        document.getElementById('b-phone').value.trim(),
            email:        document.getElementById('b-email').value.trim(),
            organisation: document.getElementById('b-org').value.trim()     || 'N/A',
            comment:      document.getElementById('b-comment').value.trim() || 'N/A',
        };

        try {
            const res  = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();

            if (data.success) {
                await triggerBrochureDownload();
                document.getElementById('brochure-form-area').style.display    = 'none';
                document.getElementById('brochure-success-area').style.display = 'flex';
            } else {
                throw new Error('Web3Forms error');
            }
        } catch (err) {
            document.getElementById('b-submit-error').style.display = 'block';
            label.innerText  = 'Submit & Download Brochure';
            btn.disabled     = false;
            console.error(err);
        }
    }

    async function triggerBrochureDownload() {
        try {
            const response = await fetch(BROCHURE_URL);
            if (!response.ok) throw new Error('Fetch failed');
            const blob    = await response.blob();
            const blobUrl = URL.createObjectURL(blob);
            const a       = document.createElement('a');
            a.href        = blobUrl;
            a.download    = 'VIGOR-S50-Brochure.pdf';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(blobUrl);
        } catch (err) {
            console.error('Download error:', err);
        }
    }
</script>

<style>
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .modal-overlay.modal-visible { display: flex; }

    .modal-box {
        background: #ffffff;
        border-radius: 14px;
        width: 100%;
        max-width: 460px;
        max-height: 90vh;
        overflow-y: auto;
        padding: 1.5rem;
        box-sizing: border-box;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .modal-box::-webkit-scrollbar { display: none; }

    @@media (prefers-color-scheme: dark) {
        .modal-box { background: #1e293b; }
    }

    .modal-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .modal-title {
        font-size: 1rem;
        font-weight: 600;
        color: #0f172a;
        margin: 0 0 3px;
    }

    .modal-subtitle {
        font-size: 0.82rem;
        color: #64748b;
        margin: 0;
    }

    @@media (prefers-color-scheme: dark) {
        .modal-title    { color: #f1f5f9; }
        .modal-subtitle { color: #94a3b8; }
    }

    .modal-close {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 4px;
        color: #64748b;
        flex-shrink: 0;
        line-height: 1;
    }

    .modal-close:hover { color: #0f172a; }

    @@media (prefers-color-scheme: dark) {
        .modal-close       { color: #94a3b8; }
        .modal-close:hover { color: #f1f5f9; }
    }

    .form-fields {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .field-label {
        font-size: 0.78rem;
        font-weight: 500;
        color: #64748b;
    }

    @@media (prefers-color-scheme: dark) {
        .field-label { color: #94a3b8; }
    }

    .required { color: #e24b4a; }
    .optional  { font-weight: 400; color: #94a3b8; }

    .field-input {
        width: 100%;
        box-sizing: border-box;
        font-size: 0.85rem;
        padding: 8px 10px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        color: #0f172a;
        outline: none;
        transition: border-color 0.15s;
        font-family: inherit;
    }

    .field-input:focus { border-color: #94a3b8; }

    @@media (prefers-color-scheme: dark) {
        .field-input {
            background: #0f172a;
            border-color: #334155;
            color: #f1f5f9;
        }
        .field-input:focus { border-color: #64748b; }
    }

    .field-textarea   { resize: vertical; min-height: 72px; }
    .field-error      { font-size: 0.75rem; color: #e24b4a; min-height: 14px; }
    .submit-error     { font-size: 0.8rem;  color: #e24b4a; text-align: center; }

    .submit-btn {
        width: 100%;
        padding: 10px;
        font-size: 0.88rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        border-radius: 8px;
        color: #ffffff;
        border: none;
        cursor: pointer;
        transition: opacity 0.15s;
        margin-top: 4px;
        font-family: inherit;
    }

    .submit-btn:hover:not(:disabled) { opacity: 0.9; }
    .submit-btn:disabled             { opacity: 0.65; cursor: not-allowed; }

    .form-hint {
        font-size: 0.72rem;
        color: #94a3b8;
        text-align: center;
        margin: 0;
    }

    .success-area {
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 1.5rem 0 0.5rem;
        text-align: center;
    }

    .success-title {
        font-size: 1rem;
        font-weight: 600;
        color: #0f172a;
        margin: 0;
    }

    .success-msg {
        font-size: 0.85rem;
        color: #64748b;
        margin: 0;
    }

    @@media (prefers-color-scheme: dark) {
        .success-title { color: #f1f5f9; }
        .success-msg   { color: #94a3b8; }
    }

    .success-close-btn {
        margin-top: 8px;
        padding: 7px 20px;
        font-size: 0.85rem;
        font-weight: 500;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: transparent;
        color: #0f172a;
        cursor: pointer;
        transition: background 0.15s;
        font-family: inherit;
    }

    .success-close-btn:hover { background: #f1f5f9; }

    @@media (prefers-color-scheme: dark) {
        .success-close-btn       { border-color: #334155; color: #f1f5f9; }
        .success-close-btn:hover { background: #334155; }
    }
</style>
