        .success-msg   { color: #94a3b8; }
    }

    .success-close-btn {
        margin-top: 8px;
        padding: 7px 20px;
        font-size: 0.85rem;
        font-weight: 500;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: transparent;
        color: #0f172a;
        cursor: pointer;
        transition: background 0.15s;
    }

    .success-close-btn:hover { background: #f1f5f9; }

    @@media (prefers-color-scheme: dark) {
        .success-close-btn { border-color: #334155; color: #f1f5f9; }
        .success-close-btn:hover { background: #334155; }
