                <div class="p-4 flex grid grid-cols-1 justify-center ">
                    <div class=" flex items-end justify-center">
                        <h1 class="text-2xl"><b>Flying is a Breeze</b></h1>
                    </div>
                    <div class="flex items-stretch justify-center">
                        <ul class="text-md md:text-lg self-start ">
                            <li>Mission repository</li>
                            <li>Context specific telemetry</li>
                            <li>Multi drone support</li>
                            <li>Windows, Linux or Android</li>
