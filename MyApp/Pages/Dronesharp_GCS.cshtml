<div id="download-modal" class="modal-overlay" onclick="handleOverlayClick(event)">
    <div class="modal-box">

        <div class="modal-header">
            <div>
                <p class="modal-title">Download Dronesharp GCS</p>
                <p class="modal-subtitle">Fill in your details to get the installer.</p>
            </div>
            <button class="modal-close" onclick="closeDownloadModal()" aria-label="Close">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
            </button>
        </div>
        <div id="form-area">
            <div class="form-fields">

                <div class="field-group">
                    <label class="field-label">Name <span class="required">*</span></label>
                    <input type="text" id="f-name" placeholder="John Smith" class="field-input" />
                    <span class="field-error" id="err-name"></span>
                </div>

                <div class="field-group">
                    <label class="field-label">Phone number <span class="required">*</span></label>
                    <input type="tel" id="f-phone" placeholder="+91 98765 43210" class="field-input" />
                    <span class="field-error" id="err-phone"></span>
                </div>

                <div class="field-group">
                    <label class="field-label">Email <span class="required">*</span></label>
                    <input type="email" id="f-email" placeholder="john@example.com" class="field-input" />
                    <span class="field-error" id="err-email"></span>
                </div>

                <div class="field-group">
                    <label class="field-label">Organisation <span class="optional">(optional)</span></label>
                    <input type="text" id="f-org" placeholder="Acme Corp" class="field-input" />
                </div>

                <div class="field-group">
                    <label class="field-label">Comment <span class="optional">(optional)</span></label>
                    <textarea id="f-comment" placeholder="Anything you'd like to tell us" rows="3" class="field-input field-textarea"></textarea>
                </div>

                <div id="submit-error" class="submit-error" style="display:none;">
                    Something went wrong. Please try again.
                </div>

                <button id="submit-btn" onclick="handleSubmit()" class="submit-btn">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;">
                        <path d="M8 2v8m0 0L5 7m3 3l3-3M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span id="submit-label">Submit &amp; Download .exe</span>
                </button>

                <p class="form-hint">Your download will start automatically after submission.</p>

            </div>
        </div>
        <div id="success-area" style="display:none;" class="success-area">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" class="success-icon">
                <circle cx="20" cy="20" r="19" stroke="#22c55e" stroke-width="1.5" />
                <path d="M12 20l6 6 10-12" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <p class="success-title">Thank you!</p>
            <p class="success-msg">Your download has started. Check your downloads folder.</p>
            <button onclick="closeDownloadModal()" class="success-close-btn">Close</button>
        </div>
    </div>
</div>

<script>
    const WEB3FORMS_KEY = '@Web3FormsAccessKey';
    const EXE_URL = '@ExeDownloadUrl';

    function openDownloadModal() {
        document.getElementById('download-modal').classList.add('modal-visible');
        document.body.style.overflow = 'hidden';
    }

    function closeDownloadModal() {
        document.getElementById('download-modal').classList.remove('modal-visible');
        document.body.style.overflow = '';
        resetForm();
    }

    function handleOverlayClick(e) {
        if (e.target === document.getElementById('download-modal')) {
            closeDownloadModal();
        }
    }

    function resetForm() {
        ['f-name','f-phone','f-email','f-org','f-comment'].forEach(id => {
            document.getElementById(id).value = '';
        });
        ['err-name','err-phone','err-email'].forEach(id => {
            document.getElementById(id).innerText = '';
        });
        document.getElementById('submit-error').style.display = 'none';
        document.getElementById('form-area').style.display = '';
        document.getElementById('success-area').style.display = 'none';
        document.getElementById('submit-label').innerText = 'Submit & Download .exe';
        document.getElementById('submit-btn').disabled = false;
    }

    function validate() {
        let valid = true;

        const name = document.getElementById('f-name').value.trim();
        const phone = document.getElementById('f-phone').value.trim();
        const email = document.getElementById('f-email').value.trim();

        document.getElementById('err-name').innerText  = '';
        document.getElementById('err-phone').innerText = '';
        document.getElementById('err-email').innerText = '';

        if (!name) {
            document.getElementById('err-name').innerText = 'Name is required.';
            valid = false;
        }
        if (!phone) {
            document.getElementById('err-phone').innerText = 'Phone number is required.';
            valid = false;
        }
        if (!email) {
            document.getElementById('err-email').innerText = 'Email is required.';
            valid = false;
        } else if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
            document.getElementById('err-email').innerText = 'Enter a valid email address.';
            valid = false;
        }

        return valid;
    }

    async function handleSubmit() {
        if (!validate()) return;

        const btn   = document.getElementById('submit-btn');
        const label = document.getElementById('submit-label');

        btn.disabled = true;
        label.innerText = 'Submitting\u2026';
        document.getElementById('submit-error').style.display = 'none';

        const payload = {
            access_key: WEB3FORMS_KEY,
            subject: 'Dronesharp GCS Download Request',
            name:         document.getElementById('f-name').value.trim(),
            phone:        document.getElementById('f-phone').value.trim(),
            email:        document.getElementById('f-email').value.trim(),
            organisation: document.getElementById('f-org').value.trim() || 'N/A',
            comment:      document.getElementById('f-comment').value.trim() || 'N/A',
        };

        try {
            const res = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const data = await res.json();

            if (data.success) {
                triggerExeDownload();
                document.getElementById('form-area').style.display = 'none';
                document.getElementById('success-area').style.display = 'flex';
            } else {
                throw new Error('Web3Forms error');
            }
        } catch (err) {
            document.getElementById('submit-error').style.display = 'block';
            label.innerText = 'Submit & Download .exe';
            btn.disabled = false;
            console.error(err);
        }
    }

    async function triggerExeDownload() {
        try {
            const response = await fetch(EXE_URL);
            if (!response.ok) throw new Error('Fetch failed');
            const blob = await response.blob();
            const blobUrl = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = blobUrl;
            a.download = 'DronesharpGCS-installer.exe';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(blobUrl);
        } catch (err) {
            console.error('Download error:', err);
        }
    }
</script>

